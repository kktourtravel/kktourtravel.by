# ============================
# Sensitive credentials and keys
# ============================
.env
.env.*
*.key
*.pem
*.crt
*.cert
*.p12
*.pfx

# ============================
# Private business and document folders
# ============================
/contracts/
/documents/
/legal/
/migration/
/clients/
/private/
/confidential/

# ============================
# System and temporary files
# ============================
.DS_Store
Thumbs.db
*.log
logs/
tmp/
.cache/

# ============================
# IDE and editor settings
# ============================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ============================
# Build and dependency folders
# ============================
node_modules/
dist/
build/

# ============================
# Backend or server-side files (future protection)
# ============================
config.php
database.php
secrets.php
*.sql

# ============================
# Image and media backups (optional)
# ============================
/licensed-image.jpeg
*.bak
*.old

# ============================
# GitHub Pages and deployment
# ============================
# Keep index.html, CNAME, and assets visible
# Ignore local preview or staging folders
/staging/
/test/
/drafts/
